# Copy this file to .env and fill in the values before running the server.
# .env is gitignored and must never be committed.

# Secret used to sign JWT tokens — use a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret

# Port the Express server listens on (default: 3000)
PORT=3000

# How long JWT tokens remain valid (jsonwebtoken format: 1h, 8h, 7d, etc.)
TOKEN_TTL=8h
